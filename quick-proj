#!/usr/bin/env bash
# quick-proj — create or refresh a coding-project scaffold.
#
# Layout (this file is the entrypoint only):
#   lib/config.sh    — config paths, scaffold dir name, project-root discovery, docs→scaffold
#   lib/version.sh   — --agent-version
#   lib/agents.sh    — copy/seed AGENT-COMMS.md + AGENT-WORKFLOW.md
#   lib/scaffold.sh  — create/--existing file layout
#   lib/update.sh    — --update
#   lib/git.sh       — optional git + GitHub
#
# Install copies this script to ~/.local/bin/quick-proj and lib/ to
# ~/.local/share/quick-proj/lib/. From a repo checkout, lib/ sits next to this file.
set -euo pipefail

usage() {
  echo "Usage: quick-proj [--no-repo] [--existing] \"project-name\""
  echo "       quick-proj --existing   # scaffold into current directory"
  echo "       quick-proj --update   # refresh scaffold agent files and add missing scaffold files"
  echo "       quick-proj --agent-version   # print this project's scaffold version and the latest"
}

# --- constants ---
SCAFFOLD_DOC_FILES=(ARCH-HUMAN.md ARCH-LLM.md)

# --- locate and load lib/ ---
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
resolve_lib_dir() {
  if [[ -d "$SCRIPT_DIR/lib" ]]; then
    printf '%s\n' "$SCRIPT_DIR/lib"
  elif [[ -d "$HOME/.local/share/quick-proj/lib" ]]; then
    printf '%s\n' "$HOME/.local/share/quick-proj/lib"
  else
    echo "Error: quick-proj library not found (expected $SCRIPT_DIR/lib or ~/.local/share/quick-proj/lib)." >&2
    return 1
  fi
}
LIB_DIR="$(resolve_lib_dir)" || exit 1
# shellcheck source=/dev/null
source "$LIB_DIR/config.sh"
# shellcheck source=/dev/null
source "$LIB_DIR/version.sh"
# shellcheck source=/dev/null
source "$LIB_DIR/agents.sh"
# shellcheck source=/dev/null
source "$LIB_DIR/scaffold.sh"
# shellcheck source=/dev/null
source "$LIB_DIR/update.sh"
# shellcheck source=/dev/null
source "$LIB_DIR/git.sh"

# --- parse args ---
no_repo=0
existing=0
update=0
agent_version=0
project_name=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-repo) no_repo=1; shift ;;
    --existing) existing=1; shift ;;
    --update) update=1; shift ;;
    --agent-version) agent_version=1; shift ;;
    -h|--help) usage; exit 0 ;;
    --) shift; break ;;
    -*)
      echo "Error: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$project_name" ]]; then
        echo "Error: unexpected argument: $1" >&2
        usage >&2
        exit 1
      fi
      project_name="$1"
      shift
      ;;
  esac
done

while [[ $# -gt 0 ]]; do
  if [[ -n "$project_name" ]]; then
    echo "Error: unexpected argument: $1" >&2
    usage >&2
    exit 1
  fi
  project_name="$1"
  shift
done

if [[ "$update" -eq 1 || "$agent_version" -eq 1 ]]; then
  if [[ "$existing" -eq 1 || "$no_repo" -eq 1 || -n "$project_name" ]]; then
    echo "Error: --update and --agent-version cannot be combined with other options or a project name." >&2
    usage >&2
    exit 1
  fi
fi

if [[ "$update" -eq 0 && "$agent_version" -eq 0 && "$existing" -eq 0 && -z "$project_name" ]]; then
  usage >&2
  exit 1
fi
if [[ -n "$project_name" && "$project_name" == */* ]]; then
  echo "Error: project name must be a single directory name." >&2
  exit 1
fi

# --- dispatch ---
if [[ "$agent_version" -eq 1 ]]; then
  run_agent_version
fi

if [[ "$update" -eq 1 ]]; then
  run_project_update
  exit 0
fi

load_scaffold_config || exit 1

if [[ "$existing" -eq 1 ]]; then
  project_dir="$(pwd)"
  if [[ -z "$project_name" ]]; then
    project_name="$(basename "$project_dir")"
  fi
else
  base_dir="${QUICK_PROJ_BASE_DIR:-${BASE_DIR:-$HOME/Documents/coding-temp}}"
  project_dir="$base_dir/$project_name"
  if [[ ! -d "$base_dir" ]]; then
    echo "Error: base directory does not exist: $base_dir" >&2
    exit 1
  fi
  if [[ -e "$project_dir" ]]; then
    echo "Error: project already exists: $project_dir" >&2
    exit 1
  fi
  mkdir -p "$project_dir"
fi

scaffold_dir="$(apply_scaffold_to_project "$project_dir" "$existing")"

if [[ "$existing" -eq 1 ]]; then
  echo "Inserted scaffold into: $project_dir" >&2
else
  echo "Created project: $project_dir" >&2
fi
echo "Scaffold folder: $scaffold_dir" >&2
echo "Templates folder: $templates_dir" >&2

if [[ "$no_repo" -eq 0 ]]; then
  setup_git_and_github "$project_dir" "$project_name"
fi

if [[ "$existing" -eq 0 ]]; then
  printf 'cd %q\n' "$project_dir"
fi
