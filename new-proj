#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: new-proj \"project-name\""
}

if [[ $# -ne 1 ]]; then
  usage
  exit 1
fi

project_name="$1"
if [[ -z "$project_name" || "$project_name" == */* ]]; then
  echo "Error: project name must be a single directory name." >&2
  exit 1
fi

config_dir="$HOME/.config/new-proj"
config_file="${NEW_PROJ_CONFIG_FILE:-$config_dir/config.env}"

if [[ -f "$config_file" ]]; then
  # shellcheck disable=SC1090
  . "$config_file"
fi

base_dir="${NEW_PROJ_BASE_DIR:-${BASE_DIR:-$HOME/Documents/coding-temp}}"
project_dir="$base_dir/$project_name"
scaffold_dir_name="${NEW_PROJ_SCAFFOLD_DIR_NAME:-${SCAFFOLD_DIR_NAME:-docs}}"
templates_dir="${NEW_PROJ_TEMPLATES_DIR:-${TEMPLATES_DIR:-$config_dir/templates}}"

if [[ -z "$scaffold_dir_name" || "$scaffold_dir_name" == */* ]]; then
  echo "Error: scaffold folder name must be a single directory name." >&2
  exit 1
fi

scaffold_dir="$project_dir/$scaffold_dir_name"

files=(
  "AGENT.md"
  "ARCHITECTURE.md"
  "README.md"
  "DEPLOY.md"
  "TODO.md"
)

if [[ ! -d "$base_dir" ]]; then
  echo "Error: base directory does not exist: $base_dir" >&2
  exit 1
fi

if [[ -e "$project_dir" ]]; then
  echo "Error: project already exists: $project_dir" >&2
  exit 1
fi

mkdir -p "$templates_dir"
mkdir -p "$scaffold_dir"

if command -v git >/dev/null 2>&1; then
  git -C "$project_dir" init >/dev/null
else
  echo "Warning: git is not installed; skipped git init." >&2
fi

for file_name in "${files[@]}"; do
  template_file="$templates_dir/$file_name"
  target_file="$scaffold_dir/$file_name"

  if [[ ! -f "$template_file" ]]; then
    : > "$template_file"
  fi

  cp "$template_file" "$target_file"
done

gitignore_template="$templates_dir/.gitignore"
gitignore_target="$project_dir/.gitignore"

if [[ ! -f "$gitignore_template" ]]; then
  cat <<'EOF' > "$gitignore_template"
# OS files
.DS_Store

# Environment files
.env
.env.*
!.env.example

# JavaScript / TypeScript
node_modules/
dist/
build/
coverage/

# Python
.venv/
__pycache__/
*.pyc
EOF
fi

cp "$gitignore_template" "$gitignore_target"

echo "Created project: $project_dir"
echo "Scaffold folder: $scaffold_dir"
echo "Templates folder: $templates_dir"
